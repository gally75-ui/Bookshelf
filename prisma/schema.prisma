generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  genre         String
  section       String   // "Child" or "Adult"
  imagePath     String
  thumbnailPath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

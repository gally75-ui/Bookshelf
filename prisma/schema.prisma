generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  genre         String
  publisher     String   @default("")
  isbn          String   @default("")
  section       String
  imagePath     String
  thumbnailPath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
